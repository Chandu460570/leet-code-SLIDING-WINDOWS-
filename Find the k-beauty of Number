class Solution(object):
    def divisorSubstrings(self, num, k):
        """
        :type num: int
        :type k: int
        :rtype: int
        """
        string=str(num)

        count=0

        for i in range(len(string)-k+1):
            digit=int(string[i:i+k])
            if digit > 0 and num % digit == 0:
                count+=1

        return count
