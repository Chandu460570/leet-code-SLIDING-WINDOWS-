class Solution(object):
    def numberOfSubstrings(self, s):
        """
        :type s: str
        :rtype: int
        """
        n = len(s)

        dici = {'a': 0, 'b': 0, 'c': 0}

        left = 0
        count = 0

        for right in range(n):

            dici[s[right]] += 1

            while dici['a'] > 0 and dici['b'] > 0 and dici['c'] > 0:

                count += n - right

                dici[s[left]] -= 1
                left += 1

        return count
